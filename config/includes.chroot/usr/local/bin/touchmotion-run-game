#!/bin/sh
set -eu

if [ -r /etc/default/touchmotion-kiosk ]; then
    . /etc/default/touchmotion-kiosk
fi

log_file="${HOME:-/tmp}/.local/state/touchmotion-kiosk.log"
mkdir -p "$(dirname "$log_file")"

if ! game_cmd="$(/usr/local/bin/touchmotion-find-game 2>/dev/null)"; then
    printf '%s run-game no-runnable-game\n' "$(date -u +%FT%TZ)" >> "$log_file"
    echo "TouchMotion kiosk: no runnable game found." >&2
    exit 1
fi

game_dir="$(dirname "$game_cmd")"
cd "$game_dir"
printf '%s run-game exec %s\n' "$(date -u +%FT%TZ)" "$game_cmd" >> "$log_file"
exec "$game_cmd"
