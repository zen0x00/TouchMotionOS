#!/bin/sh
set -eu

if [ -r /etc/default/touchmotion-kiosk ]; then
    . /etc/default/touchmotion-kiosk
fi

game_dir="${TOUCHMOTION_GAME_DIR:-/opt/touchmotion-game}"
log_file="${HOME:-/tmp}/.local/state/touchmotion-kiosk.log"

mkdir -p "$(dirname "$log_file")"
printf '%s kiosk-session entered\n' "$(date -u +%FT%TZ)" >> "$log_file"

if ! game_cmd="$(/usr/local/bin/touchmotion-find-game 2>/dev/null)"; then
    printf '%s kiosk-session no-game-found in %s\n' "$(date -u +%FT%TZ)" "$game_dir" >> "$log_file"
    cat <<EOF
TouchMotion kiosk session is configured, but no Unity game was found.
Copy one Linux Unity build into:
  $game_dir

Expected:
  - exactly one executable .x86_64 file
  - its matching *_Data directory beside it

Then rebuild the ISO and boot again.
EOF
    exit 0
fi

if [ ! -d "$XDG_RUNTIME_DIR" ]; then
    mkdir -p "$XDG_RUNTIME_DIR"
    chmod 700 "$XDG_RUNTIME_DIR"
fi

echo "Starting Cage kiosk for: $game_cmd"
printf '%s kiosk-session starting cage for %s\n' "$(date -u +%FT%TZ)" "$game_cmd" >> "$log_file"
dbus-run-session -- cage -- /usr/local/bin/touchmotion-run-game >> "$log_file" 2>&1
status=$?
printf '%s kiosk-session cage exited status=%s\n' "$(date -u +%FT%TZ)" "$status" >> "$log_file"
echo "Cage exited with status $status. Dropping to shell." >&2
exit "$status"
