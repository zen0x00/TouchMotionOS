#!/bin/sh
set -eu

# Weston DRM should be started by the autologin shell that owns tty1.
# A short delay gives the live login session time to settle.
mkdir -p "$HOME/.local/state"
printf '%s login-start begin\n' "$(date -u +%FT%TZ)" >> "$HOME/.local/state/touchmotion-kiosk.log"
sleep 2
printf '%s login-start exec kiosk-session\n' "$(date -u +%FT%TZ)" >> "$HOME/.local/state/touchmotion-kiosk.log"
exec /usr/local/bin/touchmotion-kiosk-session
